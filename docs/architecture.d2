    stroke-width: 2
    stroke-dash: 5
    font-color: "#D2B48C"
  }

  innovation_channel: |md
    ## innovation_channel
    **include/innovation_channel.hpp**
    ---
    Lock-free innovation tracking
    - `request_innovation_async()`
    - `add_gene_direct()`
    - `run_service() -> coro_task`
  | {
    style: {
      fill: "#556B2F"
      stroke: "#6B8E23"
      stroke-width: 2
      font-color: "#E8DCC8"
      stroke-dash: 5
    }
  }

  species_channel: |md
    ## species_channel
    **include/species_channel.hpp**
    ---
    Async species management
    - Channel-based requests
    - Service coroutine
  | {
    style: {
      fill: "#556B2F"
      stroke: "#6B8E23"
      stroke-width: 2
      font-color: "#E8DCC8"
      stroke-dash: 5
    }
  }
}

# ============================================================================
# VISUALIZATION
# ============================================================================
visualization: Visualization {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  network_visualizer: |md
    ## network_visualizer
    **include/network_visualizer.hpp**
    ---
    Raylib-based real-time
    neural network display
    - Node positions
    - Connection weights
    - Activation values
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
      border-radius: 6
    }
  }
}

# ============================================================================
# CONNECTIONS
# ============================================================================

# User to Model
user_layer.fitness_func -> model_layer.model: "provides evaluation" {
  style: {
    stroke: "#6B8E23"
    stroke-width: 2
  }
}

# Model to Pool
model_layer.model -> pool_layer.pool: "owns & manages" {
  style: {
    stroke: "#A0522D"
    stroke-width: 2
  }
}

# Pool to Species
pool_layer.pool -> species_layer.specie: "contains list<>" {
  style: {
    stroke: "#CD853F"
    stroke-width: 2
  }
}

# Species to Genomes
species_layer.specie -> genome_layer.genome: "contains vector<>" {
  style: {
    stroke: "#CD853F"
    stroke-width: 2
  }
}

# Genome to Brain
genome_layer.genome -> execution_layer.brain: "builds network" {
  style: {
    stroke: "#A0522D"
    stroke-width: 2
  }
}

# Brain evaluated by fitness
execution_layer.brain -> user_layer.fitness_func: "evaluated by" {
  style: {
    stroke: "#6B8E23"
    stroke-width: 2
    stroke-dash: 3
  }
}

# Pool uses async services
pool_layer.pool -> async_services.innovation_channel: "requests innovations" {
  style: {
    stroke: "#6B8E23"
    stroke-width: 2
    stroke-dash: 5
  }
}

pool_layer.pool -> async_services.species_channel: "manages species" {
  style: {
    stroke: "#6B8E23"
    stroke-width: 2
    stroke-dash: 5
  }
}

# Model uses visualizer
model_layer.model -> visualization.network_visualizer: "displays" {
  style: {
    stroke: "#708090"
    stroke-width: 1
    stroke-dash: 3
  }
}

# Brain to visualizer
execution_layer.brain -> visualization.network_visualizer: "renders" {
  style: {
    stroke: "#708090"
    stroke-width: 1
    stroke-dash: 3
  }
}
