# ENEAT System Architecture
# High-level component diagram with APIs

direction: right

# Global styling
style: {
  fill: "#2D2D2D"
}

# ============================================================================
# USER LAYER
# ============================================================================
user_layer: User Interface Layer {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  fitness_func: |md
    ## fitness_func_t
    ```cpp
    std::function<
      coro_task<size_t>(brain&)
    >
    ```
    User-defined evaluation
  | {
    style: {
      fill: "#6B8E23"
      stroke: "#556B2F"
      stroke-width: 2
      font-color: "#E8DCC8"
      border-radius: 8
    }
  }
}

# ============================================================================
# MODEL LAYER - High-level API
# ============================================================================
model_layer: Model Layer (High-Level API) {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  model: |md
    ## model
    **include/model.hpp**
    ---
    **Fields:**
    - `get_fitness: fitness_func_t`
    - `model_name: string`
    - `p: unique_ptr<pool>`
    - `tick_count: sync_shared_value<size_t>`
    - `best_fitness_: atomic<size_t>`
    - `best_brain_: brain`
    - `batch_size_: size_t`
    ---
    **Methods:**
    - `tick_async() -> coro_task<void>`
    - `evolve_async(ticks) -> coro_task<void>`
    - `evaluate_genome_copy_async(g)`
    - `get_best_brain() -> brain`
    - `save_best() / load_best()`
    - `save_pool() / load_pool()`
  | {
    style: {
      fill: "#3D3D3D"
      stroke: "#A0522D"
      stroke-width: 2
      border-radius: 8
      font-color: "#E8DCC8"
      shadow: true
    }
  }
}

# ============================================================================
# POOL LAYER - Evolution Engine
# ============================================================================
pool_layer: Pool Layer (Evolution Engine) {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  pool: |md
    ## pool
    **include/pool.hpp**
    ---
    **Fields:**
    - `innovation_chan: innovation_channel`
    - `species_chan: unique_ptr<species_channel>`
    - `species: list<specie>`
    - `best_genome_ever: optional<genome>`
    - `mutation_rates: mutation_rate_container`
    - `speciating_parameters: speciating_parameter_container`
    - `network_info: network_info_container`
    ---
    **Evolution Methods:**
    - `breed_child(s) -> coro_task<genome>`
    - `reproduce_one() -> genome`
    - `remove_worst() -> bool`
    - `add_to_species(child)`
    ---
    **Mutation Methods:**
    - `mutate(g) -> coro_task<void>`
    - `mutate_weight(g)`
    - `mutate_link(g)`
    - `mutate_neuron(g)`
    ---
    **Speciation Methods:**
    - `is_same_species(g1, g2) -> bool`
    - `disjoint(g1, g2) -> exfloat`
    - `excess(g1, g2) -> exfloat`
    - `mut_diff(g1, g2) -> exfloat`
  | {
    style: {
      fill: "#3D3D3D"
      stroke: "#A0522D"
      stroke-width: 2
      border-radius: 8
      font-color: "#E8DCC8"
      shadow: true
    }
  }
}

# ============================================================================
# SPECIES LAYER
# ============================================================================
species_layer: Species Layer {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  specie: |md
    ## specie
    **include/specie.hpp**
    ---
    **Fields:**
    - `id: size_t`
    - `age: size_t`
    - `top_fitness: sync_shared_value<size_t>`
    - `max_fitness_ever: sync_shared_value<size_t>`
    - `average_fitness: sync_shared_value<size_t>`
    - `staleness: sync_shared_value<size_t>`
    - `expected_offspring: sync_shared_value<size_t>`
    - `genomes: sync_shared_value<vector<genome>>`
    - `novel: bool`
    - `champion_preserved: bool`
    - `obliterate: bool`
  | {
    style: {
      fill: "#353535"
      stroke: "#CD853F"
      stroke-width: 2
      border-radius: 4
      font-color: "#E8DCC8"
    }
  }
}

# ============================================================================
# GENOME LAYER
# ============================================================================
genome_layer: Genome Layer {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  genome: |md
    ## genome
    **include/genome.hpp**
    ---
    **Fitness (thread-safe):**
    - `fitness: sync_shared_value<size_t>`
    - `adjusted_fitness: sync_shared_value<size_t>`
    - `time_alive: sync_shared_value<size_t>`
    ---
    **Genetic Material:**
    - `genes: map<size_t, gene>`
    - `traits: vector<trait>`
    - `max_neuron: size_t`
    ---
    **rtNEAT Metadata:**
    - `champion: bool`
    - `pop_champ: bool`
    - `eliminate: bool`
  | {
    style: {
      fill: "#353535"
      stroke: "#CD853F"
      stroke-width: 2
      border-radius: 4
      font-color: "#E8DCC8"
    }
  }
}

# ============================================================================
# EXECUTION LAYER
# ============================================================================
execution_layer: Execution Layer {
  style: {
    fill: "#2D2D2D"
    stroke: "#5A5A5A"
    stroke-dash: 3
    font-color: "#D2B48C"
  }

  brain: |md
    ## brain
    **include/brain.hpp**
    ---
    **Fields:**
    - `neurons: vector<neuron>`
    - `traits: vector<trait>`
    - `recurrent: bool`
    - `hebbian_enabled: bool`
    - `input_neurons: vector<size_t>`
    - `output_neurons: vector<size_t>`
    ---
    **Methods:**
    - `evaluate(input, output)`
    - `evaluate_nonrecurrent()`
    - `evaluate_recurrent()`
    - `apply_hebbian_learning()`
    - `flush() / reset_state()`
  | {
    style: {
      fill: "#3D3D3D"
      stroke: "#A0522D"
      stroke-width: 2
      border-radius: 8
      font-color: "#E8DCC8"
      shadow: true
    }
  }
}

