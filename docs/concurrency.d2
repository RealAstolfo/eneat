      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  batch_eval: |md
    ### Batch Evaluation
    ```
    Thread 1: [genome 0, 4, 8, ...]
    Thread 2: [genome 1, 5, 9, ...]
    Thread 3: [genome 2, 6, 10, ...]
    Thread 4: [genome 3, 7, 11, ...]

    Round-robin distribution
    batch_size = hardware_concurrency
    ```
  | {
