  }

  mutate_link_flow: |md
    ### mutate_link() Flow
    ```cpp
    coro_task<void> mutate_link(genome &g) {
      // Find valid connection
      from, to = find_valid_nodes()

      // Request innovation (async)
      size_t inn_num = co_await
        innovation_chan.request_innovation_async(
          from, to);

      // Create gene with innovation
      gene new_gene;
      new_gene.innovation_num = inn_num;
      g.genes[inn_num] = new_gene;

      co_return;
    }
    ```
  | {
    style: {
      fill: "#353535"
      stroke: "#CD853F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  mutate_neuron_flow: |md
    ### mutate_neuron() Flow
    ```cpp
    coro_task<void> mutate_neuron(genome &g) {
      // Select gene to split
      old_gene = select_random_gene()

      // Request TWO innovations (async)
      inn1 = co_await
        innovation_chan.request_innovation_async(
          old.from, new_neuron);

      inn2 = co_await
        innovation_chan.request_innovation_async(
          new_neuron, old.to);

      // Create new genes
      // ...
      co_return;
    }
    ```
  | {
    style: {
