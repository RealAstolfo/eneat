# ============================================================================
# SYNC SHARED VALUE
# ============================================================================
sync_patterns: Thread Safety Patterns {
  style: {
    fill: "#2D2D2D"
    stroke: "#8B4513"
    stroke-width: 2
    font-color: "#D2B48C"
  }

  sync_shared_value: |md
    ### sync_shared_value\<T, Policy\>
    **shared_state.hpp**
    ---
    Thread-safe value wrapper
    ```cpp
    // Mutex policy (exclusive access)
    sync_shared_value<size_t, mutex_lock_policy>
      fitness{0};

    fitness.store(100);
    size_t f = fitness.load();

    // Shared mutex policy (reader-writer)
    sync_shared_value<vector<genome>,
      shared_mutex_lock_policy> genomes{};

    // Modify with lock
    genomes.modify([](auto& v) {
      v.push_back(g);
    });
    ```
  | {
    style: {
      fill: "#8B4513"
      stroke: "#A52A2A"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  lock_policies: |md
    ### Lock Policies
    ```cpp
    mutex_lock_policy
      // Uses std::mutex
      // Exclusive read/write

    shared_mutex_lock_policy
      // Uses std::shared_mutex
      // Multiple readers, single writer
    ```
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  thread_local_rng: |md
    ### Thread-Local RNG
    **pool.hpp**
    ```cpp
    namespace eneat {
      inline thread_local std::mt19937
        tl_generator{std::random_device{}()};

      template <typename Dist>
      inline auto get_rand(Dist &d) {
        return d(tl_generator);
      }
    }
    ```
    No lock contention for random numbers
  | {
    style: {
      fill: "#6B8E23"
      stroke: "#556B2F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }
}

