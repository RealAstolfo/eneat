  tick_async: |md
    ### model::tick_async()
    ```cpp
    coro_task<void> tick_async() {
      // 1. Parallel batch evaluation
      for i in 0..batch_size:
        spawn evaluate_genome_copy_async()

      // 2. Co_await all evaluations
      for task in tasks:
        co_await task

      // 3. Remove worst (probabilistic)
      p->remove_worst_probabilistic()

      // 4. Reproduce
      genome child = p->reproduce_one()

      // 5. Add to species
      p->add_to_species(child)
    }
    ```
  | {
    style: {
      fill: "#B87333"
      stroke: "#CD7F32"
      stroke-width: 2
      font-color: "#2D2D2D"
    }
  }

  evaluate_async: |md
    ### evaluate_genome_copy_async()
    ```cpp
    coro_task<size_t> evaluate_genome_copy_async(
      genome g) {
      // Build brain from genome copy
      brain b;
      b = g;

      // Await user fitness function
      size_t fitness = co_await get_fitness(b);

      // Update fitness (thread-safe)
      // ...

      co_return fitness;
    }
    ```
  | {
    style: {
