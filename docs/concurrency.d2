# ============================================================================
# BEST GENOME TRACKING
# ============================================================================
best_tracking: Best Genome Tracking {
  style: {
    fill: "#2D2D2D"
    stroke: "#B87333"
    stroke-width: 2
    font-color: "#D2B48C"
  }

  model_tracking: |md
    ### model (Lock-Free Fitness)
    ```cpp
    atomic<size_t> best_fitness_{0};
    mutex best_brain_mutex_;
    brain best_brain_;

    void set_best_brain(brain& b, size_t fit) {
      size_t expected = best_fitness_.load();
      while (fitness > expected) {
        if (best_fitness_.compare_exchange_weak(
            expected, fitness)) {
          lock_guard lock(best_brain_mutex_);
          best_brain_ = b;
          return;
        }
      }
    }
    ```
    CAS for fitness comparison
    Mutex only for brain copy
  | {
    style: {
      fill: "#B87333"
      stroke: "#CD7F32"
      stroke-width: 2
      font-color: "#2D2D2D"
    }
  }

  pool_tracking: |md
    ### pool (Shared Mutex)
    ```cpp
    optional<genome> best_genome_ever;
    mutable shared_mutex best_genome_mutex;

    optional<genome> get_best_genome() const {
      shared_lock lock(best_genome_mutex);
      return best_genome_ever;
    }

    void update_best_genome(genome& g) {
      unique_lock lock(best_genome_mutex);
      if (!best_genome_ever or
          g.fitness > best_genome_ever->fitness) {
        best_genome_ever = g;
      }
    }
    ```
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }
}

