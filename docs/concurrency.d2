  methods: |md
    ### Methods
    ```cpp
    // Async request with callback
    void request_innovation(from, to, callback)

    // Blocking synchronous request
    size_t request_innovation_sync(from, to)

    // Coroutine-awaitable request
    coro_task<size_t> request_innovation_async(
      from, to)

    // Direct (single-threaded init only)
    size_t add_gene_direct(from, to)

    // Process pending requests
    void process_one()
    void process_all()

    // Service coroutine
    coro_task<void> run_service()
    ```
