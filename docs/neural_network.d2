    stroke-dash: 3
    font-color: "#D2B48C"
  }

  input: INPUT {
    style: {
      fill: "#6B8E23"
      stroke: "#556B2F"
      font-color: "#E8DCC8"
      border-radius: 20
    }
  }

  bias: BIAS {
    style: {
      fill: "#6B8E23"
