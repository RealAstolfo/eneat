# ============================================================================
# NEURON CONNECTION
# ============================================================================
neuron_connection: |md
  ## struct neuron_connection
  **include/neuron.hpp**
  ---
  ```cpp
  size_t from_neuron        // Source index
  exfloat weight            // Connection weight
  size_t trait_id = 0       // Hebbian trait
  bool is_recurrent = false
  bool is_time_delayed = false
    // Uses last_activation2
  exfloat params[8] = {0.0f}
  exfloat added_weight = 0.0f
    // Accumulated learning
  ```
| {
  style: {
    fill: "#353535"
    stroke: "#CD853F"
    stroke-width: 2
    font-color: "#E8DCC8"
    border-radius: 4
  }
}

# ============================================================================
# NEURON TYPES
# ============================================================================
neuron_types: Neuron Types {
