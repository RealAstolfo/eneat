    }
  }

  hidden: HIDDEN {
    style: {
      fill: "#B87333"
      stroke: "#CD7F32"
      font-color: "#2D2D2D"
      border-radius: 4
    }
  }

  output: OUTPUT {
    style: {
      fill: "#A0522D"
