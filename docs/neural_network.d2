# ENEAT Neural Network Execution
# Brain construction, neuron structure, and evaluation flow

direction: down

style: {
  fill: "#2D2D2D"
}

title: |md
  # Neural Network Construction & Evaluation
  Genome -> Brain -> Neurons -> Evaluation
| {
  style: {
    fill: "#2D2D2D"
    font-color: "#E8DCC8"
    stroke: transparent
  }
}

# ============================================================================
# BRAIN STRUCTURE
# ============================================================================
brain: |md
  ## struct brain
  **include/brain.hpp, src/brain.cpp**
| {
  style: {
    fill: "#3D3D3D"
    stroke: "#A0522D"
    stroke-width: 3
    font-color: "#E8DCC8"
    border-radius: 8
    shadow: true
  }

  fields: |md
    ### Fields
    ```cpp
    vector<neuron> neurons
    vector<trait> traits
    bool recurrent = false
    bool hebbian_enabled = false
    vector<size_t> input_neurons
    vector<size_t> bias_neurons
    vector<size_t> output_neurons
    ```
  | {
    style: {
      fill: "#353535"
      stroke: "#CD853F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  eval_methods: |md
    ### Evaluation Methods
    ```cpp
    void evaluate(input, output)
      // Dispatches to recurrent/non-recurrent

    void evaluate_nonrecurrent(input, output)
      // DFS from outputs, no cycles

    void evaluate_recurrent(input, output)
      // Time-step based, allows cycles
    ```
  | {
    style: {
      fill: "#6B8E23"
      stroke: "#556B2F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  hebbian_methods: |md
    ### Hebbian Learning Methods
    ```cpp
    void apply_hebbian_learning()
      // Modifies weights based on activations

    exfloat oldhebbian(weight, maxweight,
      active_in, active_out,
      hebb_rate, pre_rate, post_rate)
      // Original rtNEAT algorithm

    exfloat hebbian(weight, maxweight,
      active_in, active_out,
      hebb_rate, pre_rate, post_rate)
      // Floreano & Urzelai 2000
    ```
  | {
    style: {
      fill: "#8B4513"
      stroke: "#A52A2A"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  state_methods: |md
    ### State Management
    ```cpp
    void reset_state()
    void flush()
    void flushback(neuron_idx)
    void load_sensors(input)
    void override_outputs(values)
    void clear_overrides()
    bool outputs_ready()
    ```
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }
}

# ============================================================================
# NEURON STRUCTURE
# ============================================================================
neuron: |md
  ## struct neuron
  **include/neuron.hpp**
| {
  style: {
    fill: "#3D3D3D"
    stroke: "#A0522D"
    stroke-width: 3
    font-color: "#E8DCC8"
    border-radius: 8
    shadow: true
  }

  type_field: |md
    ### Type & Identity
    ```cpp
    neuron_place type = HIDDEN
    // enum: INPUT, OUTPUT, HIDDEN, BIAS
    ```
  | {
    style: {
      fill: "#6B8E23"
      stroke: "#556B2F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  activation_fields: |md
    ### Activation State
    ```cpp
    exfloat value = 0.0f
      // Current activation

    exfloat last_activation = 0.0f
      // Previous timestep (t-1)

    exfloat last_activation2 = 0.0f
      // Time-delayed (t-2)

    exfloat activation_count = 0.0f
      // Counts activations

    bool visited = false
      // For DFS traversal
    ```
  | {
    style: {
      fill: "#353535"
      stroke: "#CD853F"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  connection_field: |md
    ### Incoming Connections
    ```cpp
    vector<neuron_connection> in_connections
    ai_func_type activation_function = RELU
    ```
  | {
    style: {
      fill: "#B87333"
      stroke: "#CD7F32"
      stroke-width: 2
      font-color: "#2D2D2D"
    }
  }

  trait_field: |md
    ### Trait Parameters
    ```cpp
    size_t trait_id = 0
    exfloat params[8] = {0.0f}
    ```
  | {
    style: {
      fill: "#8B4513"
      stroke: "#A52A2A"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  override_field: |md
    ### rtNEAT Override
    ```cpp
    exfloat override_value = 0.0f
    bool override_active = false

    void override_output(new_output)
    bool overridden()
    void activate_override()
    void clear_override()
    ```
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }

  sensor_methods: |md
    ### Sensor Methods
    ```cpp
    bool sensor_load(input_value)
      // Load input without time shift

    exfloat get_active_out()
      // Returns value if activated

    exfloat get_active_out_td()
      // Time-delayed output (t-1)
    ```
  | {
    style: {
      fill: "#4A5568"
      stroke: "#708090"
      stroke-width: 2
      font-color: "#E8DCC8"
    }
  }
